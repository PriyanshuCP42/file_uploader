# === PDF AI Processing Backend ===

# Groq API Key (required) — get one at https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Server port (optional, defaults to 3001)
PORT=3001

# AI model (optional, defaults to llama-3.3-70b-versatile)
AI_MODEL=llama-3.3-70b-versatile

# Max chunk size in characters (optional, defaults to 3000)
MAX_CHUNK_SIZE=3000

# Max file size in MB (optional, defaults to 10)
MAX_FILE_SIZE_MB=10
