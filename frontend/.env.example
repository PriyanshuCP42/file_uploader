# === PDF AI Processing Frontend ===

# Cloudinary cloud name (required) — find at https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary unsigned upload preset name (required)
# Create at: Settings > Upload > Upload presets > Add > Signing Mode: Unsigned
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Backend API base URL (optional, defaults to localhost:3001)
VITE_API_BASE_URL=http://localhost:3001/api
